# =============================================================================
# OCR MCP Server — Environment Configuration
# =============================================================================
# Copy this file to .env and customize:
#   cp .env.example .env
#
# All variables have sensible defaults — in most cases you only need to
# set OCR_SERVICE_URL and OCR_SERVICE_PORT when the OCR service is remote.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
SERVER_PORT=7070
SERVER_HOST=0.0.0.0
SHUTDOWN_TIMEOUT=10s

# ---------------------------------------------------------------------------
# OCR Service
# ---------------------------------------------------------------------------
# URL of the PaddleOCR service (without port)
OCR_SERVICE_URL=http://localhost
# Port of the OCR service
OCR_SERVICE_PORT=9090
# HTTP request timeout for OCR calls
OCR_TIMEOUT=30s
# Number of retries for failed OCR requests
OCR_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------
# Cache backend: "memory" or "redis" (redis not yet implemented)
CACHE_TYPE=memory
# Default TTL for cached OCR results
CACHE_TTL=1h
# Maximum number of entries in the in-memory cache
CACHE_MAX_SIZE=1000

# Redis connection (only used when CACHE_TYPE=redis)
# REDIS_URL=localhost:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ---------------------------------------------------------------------------
# Worker Pool
# ---------------------------------------------------------------------------
# Number of concurrent OCR workers (default: CPU count)
WORKER_COUNT=4
# Maximum queued jobs
QUEUE_SIZE=100
# Per-job timeout
JOB_TIMEOUT=60s

# ---------------------------------------------------------------------------
# Image Preprocessing
# ---------------------------------------------------------------------------
# Maximum image width in pixels (larger images are resized)
MAX_IMAGE_WIDTH=4096
# Maximum image height in pixels (larger images are resized)
MAX_IMAGE_HEIGHT=4096
# Maximum image file size in MB
MAX_IMAGE_SIZE_MB=20
# Enable automatic preprocessing (grayscale + denoise + threshold)
AUTO_PREPROCESS=true

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------
# Default output format: "markdown" or "json"
OUTPUT_FORMAT=markdown

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# API key for securing MCP endpoints (optional, leave empty to disable)
API_KEY=

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
# Maximum requests per minute per client
RATE_LIMIT_PER_MIN=60

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Vision service (optional)
# VISION_SERVICE_URL=http://localhost:9080

# ---------------------------------------------------------------------------
# OCR Service (Python) — only used in Docker Compose
# ---------------------------------------------------------------------------
# OCR_USE_GPU=false
# OCR_LANG=en
# OCR_LOG_LEVEL=info
# OCR_MAX_IMAGE_SIZE_MB=20
